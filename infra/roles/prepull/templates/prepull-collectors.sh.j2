#!/usr/bin/env bash
# Auto-generated by Ansible. Pulls the pinned collector images for the playground.
set -euo pipefail

images=(
{% for img in collector_images %}
  "{{ img }}"
{% endfor %}
)

for img in "${images[@]}"; do
  echo "Pulling ${img}..."
  docker pull --quiet "${img}"
done

# Reclaim space from untagged layers.
docker image prune -f >/dev/null
